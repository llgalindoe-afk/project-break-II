{
  "openapi": "3.0.0",
  "info": {
    "title": "E-Commerce API",
    "version": "1.0.0",
    "description": "API for E-Commerce project with Supabase and MongoDB"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor de Desarrollo Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "UserRegisterInput": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "testuser@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "password123"
          }
        }
      },
      "UserLoginInput": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "admin@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "admin123"
          }
        }
      },
      "ProductInput": {
        "type": "object",
        "required": [
          "name",
          "price"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "iPhone 15 Pro Max"
          },
          "price": {
            "type": "number",
            "format": "float",
            "example": 1299.99
          },
          "description": {
            "type": "string",
            "example": "Último modelo de iPhone con acabado de titanio y chip A17 Pro."
          },
          "imageUrl": {
            "type": "string",
            "example": "https://example.com/iphone15.jpg"
          }
        }
      },
      "ReviewInput": {
        "type": "object",
        "required": [
          "rating",
          "comment"
        ],
        "properties": {
          "rating": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "example": 5
          },
          "comment": {
            "type": "string",
            "example": "Excelente producto, superó mis expectativas."
          }
        }
      },
      "CartItemInput": {
        "type": "object",
        "required": [
          "productId",
          "quantity"
        ],
        "properties": {
          "productId": {
            "type": "integer",
            "example": 1
          },
          "quantity": {
            "type": "integer",
            "example": 2
          }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Verificar el estado de salud de la API",
        "description": "Devuelve un estado simple indicando que el servidor de la API está levantado y corriendo.",
        "responses": {
          "200": {
            "description": "Estado saludable"
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Registrar un nuevo usuario",
        "description": "Crea una cuenta de usuario con rol 'user' de forma predeterminada.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserRegisterInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuario registrado exitosamente"
          },
          "400": {
            "description": "Datos de entrada inválidos"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Iniciar sesión y obtener token",
        "description": "Valida las credenciales, genera un token JWT en el cuerpo JSON de la respuesta y establece la cookie de sesión.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserLoginInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Inicio de sesión exitoso"
          },
          "401": {
            "description": "Credenciales inválidas"
          }
        }
      }
    },
    "/api/me": {
      "get": {
        "summary": "Obtener perfil del usuario autenticado",
        "description": "Devuelve la información de perfil del usuario a partir del token JWT Bearer proporcionado.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Datos del perfil devueltos exitosamente"
          },
          "401": {
            "description": "No autorizado"
          }
        }
      }
    },
    "/api/products": {
      "get": {
        "summary": "Listar todos los productos",
        "description": "Obtiene la lista completa de productos disponibles.",
        "responses": {
          "200": {
            "description": "Lista de productos devuelta exitosamente"
          }
        }
      },
      "post": {
        "summary": "Crear un nuevo producto",
        "description": "Permite registrar un nuevo producto en el catálogo. Requiere privilegios de administrador.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Producto creado con éxito"
          },
          "403": {
            "description": "Acceso denegado (requiere rol admin)"
          }
        }
      }
    },
    "/api/products/{id}": {
      "get": {
        "summary": "Obtener un producto por ID",
        "description": "Obtiene los detalles de un producto específico.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID numérico del producto",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detalles del producto"
          },
          "404": {
            "description": "Producto no encontrado"
          }
        }
      },
      "put": {
        "summary": "Actualizar un producto por ID",
        "description": "Actualiza la información de un producto existente. Requiere privilegios de administrador.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID del producto a actualizar",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Producto actualizado con éxito"
          },
          "403": {
            "description": "Acceso denegado (requiere rol admin)"
          }
        }
      },
      "delete": {
        "summary": "Eliminar un producto por ID",
        "description": "Elimina un producto del catálogo. Requiere privilegios de administrador.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID del producto a eliminar",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Producto eliminado con éxito"
          },
          "403": {
            "description": "Acceso denegado"
          }
        }
      }
    },
    "/api/products/{id}/reviews": {
      "get": {
        "summary": "Obtener reseñas de un producto (MongoDB)",
        "description": "Obtiene la lista de reseñas del producto a partir del ID de producto.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID numérico del producto",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de reseñas"
          }
        }
      },
      "post": {
        "summary": "Crear reseña para un producto (MongoDB)",
        "description": "Agrega una nueva reseña al producto especificado. Requiere autenticación.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID numérico del producto a reseñar",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReviewInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Reseña añadida con éxito"
          },
          "401": {
            "description": "No autorizado"
          }
        }
      }
    },
    "/api/wishlist": {
      "get": {
        "summary": "Obtener wishlist del usuario",
        "description": "Devuelve los elementos guardados en la wishlist del usuario autenticado.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de la wishlist"
          },
          "401": {
            "description": "No autorizado"
          }
        }
      }
    },
    "/api/wishlist/{productId}": {
      "post": {
        "summary": "Añadir o remover un producto de la wishlist (Toggle)",
        "description": "Añade el producto a la wishlist si no estaba presente, o lo remueve si ya existía. Requiere autenticación.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "description": "ID numérico del producto",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Estado de la wishlist actualizado con éxito"
          },
          "401": {
            "description": "No autorizado"
          }
        }
      }
    },
    "/api/whislist": {
      "get": {
        "summary": "Obtener wishlist del usuario (Alias)",
        "description": "Alias con tolerancia a typo del endpoint principal de wishlist.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de la wishlist"
          }
        }
      }
    },
    "/api/whislist/{productId}": {
      "post": {
        "summary": "Añadir o remover de la wishlist (Toggle - Alias)",
        "description": "Alias con tolerancia a typo del endpoint principal de wishlist.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Estado de la wishlist actualizado"
          }
        }
      }
    },
    "/api/cart": {
      "get": {
        "summary": "Ver el carrito activo del usuario",
        "description": "Obtiene los detalles del carrito activo del usuario. Si no existe, se crea automáticamente un carrito activo.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Detalles del carrito"
          },
          "401": {
            "description": "No autorizado"
          }
        }
      }
    },
    "/api/cart/items": {
      "post": {
        "summary": "Añadir producto al carrito",
        "description": "Añade un producto al carrito activo del usuario autenticado. Requiere autenticación.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CartItemInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Item añadido al carrito"
          },
          "401": {
            "description": "No autorizado"
          }
        }
      }
    },
    "/api/cart/items/{itemID}": {
      "delete": {
        "summary": "Eliminar item del carrito por ID de item",
        "description": "Elimina una entrada de producto específica (cartItem) del carrito del usuario utilizando su ID de item. Requiere autenticación.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "itemID",
            "in": "path",
            "required": true,
            "description": "ID numérico de la entrada cartItem",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item eliminado con éxito"
          },
          "401": {
            "description": "No autorizado"
          },
          "404": {
            "description": "El item no existe"
          }
        }
      }
    },
    "/api/cart/checkout": {
      "post": {
        "summary": "Realizar checkout del carrito",
        "description": "Procesa el carrito activo, crea el pedido correspondiente y marca el carrito como 'CHECKED_OUT'. Requiere autenticación.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Pedido creado con éxito"
          },
          "400": {
            "description": "El carrito está vacío o no hay carrito activo"
          },
          "401": {
            "description": "No autorizado"
          }
        }
      }
    },
    "/api/docs": {
      "get": {
        "summary": "Acceso a la documentación interactiva de Swagger UI",
        "description": "Endpoint desde el cual se sirve esta documentación interactiva.",
        "responses": {
          "200": {
            "description": "Página de Swagger UI"
          }
        }
      }
    }
  }
}
