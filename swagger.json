{
  "openapi": "3.0.0",
  "info": {
    "title": "E-Commerce API",
    "version": "1.0.0",
    "description": "API for E-Commerce project with Supabase and MongoDB"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor de Desarrollo Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "UserRegisterInput": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "testuser@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "password123"
          }
        }
      },
      "UserLoginInput": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "admin@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "admin123"
          }
        }
      },
      "ProductInput": {
        "type": "object",
        "required": [
          "name",
          "price"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "iPhone 15 Pro Max"
          },
          "price": {
            "type": "number",
            "format": "float",
            "example": 1299.99
          },
          "description": {
            "type": "string",
            "example": "Último modelo de iPhone con acabado de titanio y chip A17 Pro."
          },
          "imageUrl": {
            "type": "string",
            "example": "https://example.com/iphone15.jpg"
          }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Verificar el estado de salud de la API",
        "description": "Devuelve un estado simple indicando que el servidor de la API está levantado y corriendo.",
        "responses": {
          "200": {
            "description": "Estado saludable",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "example": true
                    },
                    "status": {
                      "type": "string",
                      "example": "healthy"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Registrar un nuevo usuario",
        "description": "Crea una cuenta de usuario con rol 'user' de forma predeterminada.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserRegisterInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuario registrado exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Usuario registrado con éxito"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 1
                        },
                        "email": {
                          "type": "string",
                          "example": "testuser@example.com"
                        },
                        "role": {
                          "type": "string",
                          "example": "user"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Datos de entrada inválidos o email ya registrado"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Iniciar sesión y obtener token",
        "description": "Valida las credenciales, genera un token JWT en el cuerpo JSON de la respuesta y establece la cookie de sesión.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserLoginInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Inicio de sesión exitoso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "El login se realizó con éxito"
                    },
                    "token": {
                      "type": "string",
                      "description": "Copia este token para el diálogo Authorize",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Faltan email o contraseña"
          },
          "401": {
            "description": "Credenciales inválidas"
          }
        }
      }
    },
    "/api/me": {
      "get": {
        "summary": "Obtener perfil del usuario autenticado",
        "description": "Devuelve la información de perfil del usuario a partir del token JWT Bearer proporcionado.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Datos del perfil devueltos exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 2
                        },
                        "email": {
                          "type": "string",
                          "example": "admin@example.com"
                        },
                        "role": {
                          "type": "string",
                          "example": "admin"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "No autorizado. Token no proporcionado o expirado."
          }
        }
      }
    },
    "/api/products": {
      "get": {
        "summary": "Listar todos los productos",
        "description": "Obtiene la lista completa de productos disponibles.",
        "responses": {
          "200": {
            "description": "Lista de productos devuelta exitosamente"
          }
        }
      },
      "post": {
        "summary": "Crear un nuevo producto",
        "description": "Permite registrar un nuevo producto en el catálogo. Requiere privilegios de administrador.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Producto creado con éxito"
          },
          "400": {
            "description": "Faltan campos obligatorios"
          },
          "401": {
            "description": "No autorizado (falta token o es inválido)"
          },
          "403": {
            "description": "Acceso denegado (requiere rol admin)"
          }
        }
      }
    },
    "/api/products/{id}": {
      "get": {
        "summary": "Obtener un producto por ID",
        "description": "Obtiene los detalles de un producto específico.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID numérico del producto",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detalles del producto"
          },
          "400": {
            "description": "ID inválido"
          },
          "404": {
            "description": "Producto no encontrado"
          }
        }
      },
      "put": {
        "summary": "Actualizar un producto por ID",
        "description": "Actualiza la información de un producto existente. Requiere privilegios de administrador.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID numérico del producto a actualizar",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Producto actualizado con éxito"
          },
          "400": {
            "description": "ID inválido o datos incorrectos"
          },
          "401": {
            "description": "No autorizado"
          },
          "403": {
            "description": "Acceso denegado (requiere rol admin)"
          },
          "404": {
            "description": "Producto no encontrado"
          }
        }
      },
      "delete": {
        "summary": "Eliminar un producto por ID",
        "description": "Elimina un producto del catálogo. Requiere privilegios de administrador.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID numérico del producto a eliminar",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Producto eliminado con éxito"
          },
          "400": {
            "description": "ID inválido"
          },
          "401": {
            "description": "No autorizado"
          },
          "403": {
            "description": "Acceso denegado (requiere rol admin)"
          },
          "404": {
            "description": "Producto no encontrado"
          }
        }
      }
    }
  }
}
